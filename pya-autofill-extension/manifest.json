{
  "manifest_version": 3,
  "name": "Cargo → PYA Autofill",
  "version": "1.0.0",
  "description": "Fills the PYA Sea Service Testimonial (SST) form from a crew member's Cargo record.",
  "permissions": ["clipboardRead", "scripting"],
  "host_permissions": ["https://member.pya.org/*"],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_title": "Fill PYA form from Cargo",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://member.pya.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
